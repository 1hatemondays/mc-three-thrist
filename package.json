{
  "name": "maze-of-knowledge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "server",
    "host",
    "player"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace host\" \"npm run dev --workspace player\"",
    "dev:server": "npm run dev --workspace server",
    "dev:host": "npm run dev --workspace host",
    "dev:player": "npm run dev --workspace player",
    "build": "npm run build --workspace host && npm run build --workspace player",
    "start": "npm run start --workspace server",
    "test": "node --test server/*.test.js shared/*.test.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "type": "module"
}
